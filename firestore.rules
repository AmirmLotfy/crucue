rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ─────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function isValidString(field, minLen, maxLen) {
      return field is string && field.size() >= minLen && field.size() <= maxLen;
    }

    // ─── Users ────────────────────────────────────────────────────────────────

    match /users/{uid} {
      allow read: if isAuthenticated() && isOwner(uid);
      allow create: if isAuthenticated() && isOwner(uid)
        && isValidString(request.resource.data.email, 1, 320);
      allow update: if isAuthenticated() && isOwner(uid);
      allow delete: if isAuthenticated() && isOwner(uid);

      // ─── Legacy history (Phase 2 bridge collection) ────────────────────────
      match /history/{historyId} {
        allow read, write: if isAuthenticated() && isOwner(uid);
      }

      // ─── Care Profiles ────────────────────────────────────────────────────

      match /profiles/{profileId} {
        allow read: if isAuthenticated() && isOwner(uid);
        allow create: if isAuthenticated() && isOwner(uid)
          && isValidString(request.resource.data.name, 1, 100)
          && request.resource.data.relationship in
             ['child', 'parent', 'partner', 'sibling', 'familyMember'];
        allow update: if isAuthenticated() && isOwner(uid);
        allow delete: if isAuthenticated() && isOwner(uid);

        // ─── Incidents ──────────────────────────────────────────────────────

        match /incidents/{incidentId} {
          allow read: if isAuthenticated() && isOwner(uid);
          allow create: if isAuthenticated() && isOwner(uid)
            && isValidString(request.resource.data.title, 1, 200)
            && isValidString(request.resource.data.description, 1, 5000)
            && request.resource.data.intensity is int
            && request.resource.data.intensity >= 1
            && request.resource.data.intensity <= 5;
          allow update: if isAuthenticated() && isOwner(uid);
          allow delete: if isAuthenticated() && isOwner(uid);
        }

        // ─── Support Plans ───────────────────────────────────────────────────
        // Plans are generated by Cloud Functions and the Crucue app client.
        // The client saves plans directly (via FirestoreService.savePlanWithContext).
        // AI-generated plans from Cloud Functions use Admin SDK (bypasses rules).
        // Only read and delete allowed from client; create is allowed for client-saved plans.

        match /plans/{planId} {
          allow read: if isAuthenticated() && isOwner(uid);
          allow create: if isAuthenticated() && isOwner(uid)
            && isValidString(request.resource.data.summary, 1, 5000);
          // No client updates — plans are immutable once created.
          allow delete: if isAuthenticated() && isOwner(uid);
        }

        // ─── Routines ────────────────────────────────────────────────────────

        match /routines/{routineId} {
          allow read, write: if isAuthenticated() && isOwner(uid);
        }

        // ─── Check-Ins ───────────────────────────────────────────────────────

        match /checkins/{checkinId} {
          allow read: if isAuthenticated() && isOwner(uid);
          allow create: if isAuthenticated() && isOwner(uid);
          allow update: if isAuthenticated() && isOwner(uid);
          allow delete: if isAuthenticated() && isOwner(uid);
        }

        // ─── Insights ────────────────────────────────────────────────────────

        match /insights/{insightId} {
          allow read: if isAuthenticated() && isOwner(uid);
          allow create: if isAuthenticated() && isOwner(uid);
          allow delete: if isAuthenticated() && isOwner(uid);
        }

        // ─── Voice Notes ──────────────────────────────────────────────────────
        // Client creates the initial record and is allowed to update only the
        // linkedIncidentId field (after review). The status, transcript, and
        // extractedIncident fields are written by Cloud Functions via Admin SDK.

        match /voiceNotes/{voiceNoteId} {
          allow read: if isAuthenticated() && isOwner(uid);
          allow create: if isAuthenticated() && isOwner(uid)
            && isValidString(request.resource.data.profileId, 1, 128);
          // Client may only update the linkedIncidentId link after review.
          allow update: if isAuthenticated() && isOwner(uid)
            && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['linkedIncidentId']);
          allow delete: if isAuthenticated() && isOwner(uid);
        }
      }

      // ─── Chat Threads ─────────────────────────────────────────────────────

      // FCM device tokens (one doc per app installation)
      match /devices/{deviceId} {
        allow read: if isAuthenticated() && isOwner(uid);
        allow create, update: if isAuthenticated() && isOwner(uid)
          && request.resource.data.token is string
          && request.resource.data.token.size() >= 10
          && request.resource.data.token.size() <= 4096
          && request.resource.data.platform in ['ios', 'android', 'unknown'];
        allow delete: if isAuthenticated() && isOwner(uid);
      }

      match /chatThreads/{threadId} {
        allow read, write: if isAuthenticated() && isOwner(uid);

        match /messages/{messageId} {
          allow read: if isAuthenticated() && isOwner(uid);
          allow create: if isAuthenticated() && isOwner(uid)
            && request.resource.data.role in ['user', 'assistant']
            && isValidString(request.resource.data.content, 1, 10000);
          allow delete: if isAuthenticated() && isOwner(uid);
        }
      }
    }

    // ─── Deny all other access ─────────────────────────────────────────────

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
