# Copy this file to .env and fill in your values.
# Never commit the .env file with real values.
#
# Crucue uses Gemma 4 as its AI backbone.
#
# To use Firebase Secrets Manager instead (recommended for production):
#   firebase functions:secrets:set GEMMA4_API_KEY
#   firebase functions:secrets:set GEMMA4_MODEL
#
# For local development with emulator:
GEMMA4_API_KEY=your-gemma4-api-key-here
GEMMA4_MODEL=gemma-4-26b-a4b-it
#
# Model identifiers (per Google AI docs — Gemini Developer API):
# Remote (default):  gemma-4-26b-a4b-it — 26B MoE, instruction-tuned, production default
# Remote (premium):  gemma-4-31b-it     — 31B dense, instruction-tuned (planned)
# On-device (fast):  gemma-4-e2b-it    — 2B on-device, Android AICore / LiteRT-LM
# On-device (quality): gemma-4-e4b-it  — 4B on-device, higher quality on-device
#
# The on-device models are served via native Android/iOS platform channels
# (see lib/core/ai/native/on_device_channel.dart) and do NOT need an API key.
