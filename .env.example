# Crucue — root environment example
#
# This file documents environment variables used across the project.
# Never commit .env files with real values.
#
# Each sub-project has its own .env.example:
#   functions/.env.example       — Firebase Cloud Functions
#   backend/ai-gateway/.env.example — Cloud Run AI Gateway

# ─── Firebase (client-side config — NOT secrets) ──────────────────────────────
# These are baked into the app via FlutterFire and platform config files.
# They are not secrets, but should reflect your Firebase project.
#
# Android: android/app/google-services.json (gitignored — add manually)
# iOS:     ios/Runner/GoogleService-Info.plist (gitignored — add manually)
# Dart:    lib/firebase_options.dart (generated by FlutterFire CLI)

FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_APP_ID_ANDROID=1:000000000000:android:xxxxxxxxxxxx
FIREBASE_APP_ID_IOS=1:000000000000:ios:xxxxxxxxxxxx

# ─── AI (server-side only — never in the Flutter app) ─────────────────────────
# Set via Firebase Secrets Manager in production:
#   firebase functions:secrets:set GEMMA4_API_KEY
#
# For local Cloud Functions development, copy functions/.env.example → functions/.env
# GEMMA4_API_KEY=your-gemma4-api-key-here

# ─── App environment ──────────────────────────────────────────────────────────
# Passed via --dart-define at build time:
#   flutter run --dart-define=ENV=dev
#   flutter build apk --dart-define=ENV=staging
#   flutter build apk --release   (defaults to prod)
ENV=dev
