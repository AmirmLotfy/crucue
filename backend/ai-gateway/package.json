{
  "name": "crucue-ai-gateway",
  "version": "1.0.0",
  "description": "Crucue Cloud Run AI Gateway — orchestrates Gemma 4 inference via Vertex AI",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "lint": "eslint 'src/**/*.ts'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google-cloud/aiplatform": "^3.19.0",
    "@google-cloud/firestore": "^7.6.0",
    "express": "^4.19.2",
    "firebase-admin": "^12.2.0",
    "ajv": "^8.16.0",
    "ajv-formats": "^3.0.1",
    "winston": "^3.13.0",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "express-rate-limit": "^7.3.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.14.2",
    "typescript": "^5.4.5",
    "ts-node-dev": "^2.0.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^9.5.0"
  },
  "engines": {
    "node": ">=20"
  }
}
