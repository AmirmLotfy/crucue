# Crucue AI Gateway — environment variables
# Copy to .env.local for development. Never commit .env with real values.

# ─── Google Cloud ─────────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=octifyai
VERTEX_AI_LOCATION=us-central1

# ─── Gemma 4 model identifiers ────────────────────────────────────────────────
# Remote default  (26B Mixture-of-Experts, Vertex AI)
GEMMA4_DEFAULT_MODEL=gemma-4-26b-a4b-it
# Remote premium  (31B dense, deeper reasoning, higher cost)
GEMMA4_PREMIUM_MODEL=gemma-4-31b-it
# On-device fast  (2B, Android AICore / LiteRT-LM)
GEMMA4_ONDEVICE_FAST=gemma-4-e2b-it
# On-device quality (4B, iPhone 15+ / high-RAM Android)
GEMMA4_ONDEVICE_QUALITY=gemma-4-e4b-it

# ─── Firebase Admin ───────────────────────────────────────────────────────────
# When running on Cloud Run, application default credentials are used
# automatically. Set this only for local development:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=production

# ─── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

# ─── Caching ──────────────────────────────────────────────────────────────────
# Response caching TTL in seconds (0 = disabled)
CACHE_TTL_SECONDS=300
